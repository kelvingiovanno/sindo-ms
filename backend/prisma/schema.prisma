generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  ADMIN
  STAFF
  VIEWER
}

model User {
  id String @id @default(uuid())
  role UserRole @default(VIEWER)
  fullname String
  username String @unique
  password String
  isRevoked Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens Refresh[]
  storeAccesses StoreAccess[]
}

model Refresh {
  id String   @id @default(uuid())
  token String @db.Text
  userId String
  createdAt DateTime @default(now())
  expiresIn DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Store {
  id String @id @default(uuid())
  name String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  storeAccesses StoreAccess[]
}

model StoreAccess {
  storeId String 
  userId String
  
  stores Store @relation(fields: [storeId], references: [id])
  users User @relation(fields: [userId], references: [id])

  @@id([storeId, userId])
}

model ProductCategory {
  id String @id @default(uuid())
  name String @unique
  products Product[]
}

model ProductBrand {
  id String @id @default(uuid())
  name String @unique
  products Product[]
}

model ProductUnit {
  id String @id @default(uuid())
  name String @unique
  symbol String @unique
  products Product[]
}

model Supplier {
  id String @id @default(uuid())
  name String
  phone String @unique
  email String @unique
  address String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  products Product[]
}

model Product {
  id String @id @default(uuid())
  storeId String
  sku String @unique
  name String
  partnumber String
  description String
  cost Decimal
  price Decimal
  stock Decimal
  categoryId String
  brandId String
  unitId String
  supplierId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  category ProductCategory @relation(fields: [categoryId], references: [id])
  brand ProductBrand @relation(fields: [brandId], references: [id])
  unit ProductUnit @relation(fields: [unitId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  dimensions ProductDimension[]
}

model MeasurementUnit {
  id String @id @default(uuid())
  name String @unique
  symbol String @unique
}

model ProductDimension {
  id String @id @default(uuid())
  productId String 
  measurement String
  value Decimal
  unitId String
  product Product @relation(fields: [productId], references: [id])
}